FROM python:3.11-slim

# git is needed by build_bindings.sh to clone the OpenConfig YANG models
RUN apt-get update && apt-get install -y --no-install-recommends git \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

# NOTE: oc_bindings/ is generated by build_bindings.sh and is gitignored.
# Run it once during image build (requires network access at build time),
# or mount a pre-built oc_bindings/ as a volume.
# RUN ./build_bindings.sh

EXPOSE 8080

CMD ["python", "main.py", "serve"]
